{
  "name": "nexpress",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "turbo": "2.9.12"
  },
  "scripts": {
    "dev": "pnpm --filter @nexpress/web dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  }
}
