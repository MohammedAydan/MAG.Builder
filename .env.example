NODE_ENV=development
PAYLOAD_SECRET=YOUR_SECRET_HERE
DATABASE_URL=postgres://127.0.0.1:5432/nexpress
NEXPRESS_INSTALLATION_MODE=wizard
NEXPRESS_DEFAULT_SITE_NAME=NexPress Local
NEXPRESS_TRUST_PROXY_HOST=false
NEXPRESS_COMMERCE_PROVIDER=disabled
MEDUSA_BACKEND_URL=http://127.0.0.1:9000
MEDUSA_DEFAULT_REGION_ID=reg_test
MEDUSA_HEALTH_PATH=/health
MEDUSA_PUBLISHABLE_KEY=pk_test_placeholder
MEDUSA_SERVER_TOKEN=medusa_server_token_placeholder
MEDUSA_REQUEST_TIMEOUT_MS=5000
NEXPRESS_FORM_RATE_LIMIT_PROVIDER=memory
NEXPRESS_EMAIL_PROVIDER=stub
NEXPRESS_EMAIL_FROM=ops@example.com
NEXPRESS_EMAIL_REPLY_TO=help@example.com
RESEND_API_KEY=re_placeholder
NEXPRESS_SEARCH_PROVIDER=database
NEXPRESS_ANALYTICS_PROVIDER=audit-log
NEXPRESS_WEBHOOK_DELIVERY_MODE=in-process
NEXPRESS_WEBHOOK_MAX_ATTEMPTS=3
NEXPRESS_WEBHOOK_BACKOFF_MS=30000

# Seed — local development only. Never use real credentials here.
# These are used by `pnpm seed` to create the first admin user idempotently.
# In production, use the install wizard (Phase 05) instead.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-please
